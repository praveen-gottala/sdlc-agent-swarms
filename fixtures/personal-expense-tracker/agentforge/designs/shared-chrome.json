{
  "screen": "__chrome__",
  "width": 1440,
  "nodes": {
    "root": {
      "parent": null,
      "order": 0,
      "type": "page",
      "width": 1440,
      "layout": {
        "dir": "column",
        "gap": 0
      },
      "background": "background-primary"
    },
    "top-bar": {
      "parent": "root",
      "order": 0,
      "type": "header",
      "width": "fill",
      "height": 64,
      "background": "surface-primary",
      "layout": {
        "dir": "row",
        "align": "center",
        "justify": "space-between",
        "px": 24,
        "py": 0
      },
      "shadow": "sm",
      "overrides": {
        "borderBottom": "1px solid var(--border-default)",
        "position": "fixed",
        "top": 0,
        "zIndex": 100
      }
    },
    "top-bar-left": {
      "parent": "top-bar",
      "order": 0,
      "type": "container",
      "layout": {
        "dir": "row",
        "align": "center",
        "gap": 4
      }
    },
    "app-logo": {
      "parent": "top-bar-left",
      "order": 0,
      "type": "container",
      "layout": {
        "dir": "row",
        "align": "center",
        "gap": 8
      }
    },
    "app-logo-icon": {
      "parent": "app-logo",
      "order": 0,
      "catalog": "icon",
      "overrides": {
        "name": "wallet",
        "color": "#F59E0B",
        "size": 24
      }
    },
    "app-logo-text": {
      "parent": "app-logo",
      "order": 1,
      "type": "text",
      "content": "BudgetWise",
      "typography": "heading-3",
      "color": "text-primary",
      "weight": 700
    },
    "month-selector": {
      "parent": "top-bar",
      "order": 1,
      "type": "container",
      "layout": {
        "dir": "row",
        "align": "center",
        "gap": 8
      }
    },
    "prev-month-btn": {
      "parent": "month-selector",
      "order": 0,
      "type": "container",
      "width": 44,
      "height": 44,
      "layout": {
        "dir": "row",
        "align": "center",
        "justify": "center"
      },
      "radius": 10,
      "overrides": {
        "cursor": "pointer"
      }
    },
    "prev-month-icon": {
      "parent": "prev-month-btn",
      "order": 0,
      "catalog": "icon",
      "overrides": {
        "name": "chevron-left"
      },
      "color": "text-primary"
    },
    "month-year-label": {
      "parent": "month-selector",
      "order": 1,
      "type": "text",
      "content": "January 2025",
      "typography": "heading-3",
      "color": "text-primary",
      "weight": 600,
      "overrides": {
        "minWidth": 140,
        "textAlign": "center"
      }
    },
    "next-month-btn": {
      "parent": "month-selector",
      "order": 2,
      "type": "container",
      "width": 44,
      "height": 44,
      "layout": {
        "dir": "row",
        "align": "center",
        "justify": "center"
      },
      "radius": 10,
      "overrides": {
        "cursor": "pointer"
      }
    },
    "next-month-icon": {
      "parent": "next-month-btn",
      "order": 0,
      "catalog": "icon",
      "overrides": {
        "name": "chevron-right"
      },
      "color": "text-primary"
    },
    "top-bar-actions": {
      "parent": "top-bar",
      "order": 2,
      "type": "container",
      "layout": {
        "dir": "row",
        "align": "center",
        "gap": 8
      }
    },
    "settings-icon-btn": {
      "parent": "top-bar-actions",
      "order": 0,
      "type": "container",
      "width": 44,
      "height": 44,
      "layout": {
        "dir": "row",
        "align": "center",
        "justify": "center"
      },
      "radius": 10,
      "navigateTo": "settings",
      "overrides": {
        "cursor": "pointer"
      }
    },
    "settings-icon": {
      "parent": "settings-icon-btn",
      "order": 0,
      "catalog": "icon",
      "overrides": {
        "name": "settings"
      },
      "color": "text-secondary"
    },
    "nav-tabs": {
      "parent": "root",
      "order": 1,
      "type": "container",
      "width": "fill",
      "height": 64,
      "background": "surface-primary",
      "layout": {
        "dir": "row",
        "align": "center",
        "justify": "space-between",
        "px": 24,
        "py": 0
      },
      "overrides": {
        "borderTop": "1px solid var(--border-default)",
        "position": "fixed",
        "bottom": 0,
        "zIndex": 100
      }
    },
    "home-tab": {
      "parent": "nav-tabs",
      "order": 0,
      "type": "container",
      "height": 44,
      "layout": {
        "dir": "column",
        "align": "center",
        "justify": "center",
        "gap": 4,
        "px": 24,
        "py": 8
      },
      "radius": 6,
      "overrides": {
        "cursor": "pointer",
        "flex": 1
      }
    },
    "home-tab-icon": {
      "parent": "home-tab",
      "order": 0,
      "catalog": "icon",
      "overrides": {
        "name": "home",
        "color": "#F59E0B"
      }
    },
    "home-tab-label": {
      "parent": "home-tab",
      "order": 1,
      "type": "text",
      "content": "Home",
      "typography": "label",
      "color": "cta-primary",
      "weight": 600
    },
    "add-expense-tab": {
      "parent": "nav-tabs",
      "order": 1,
      "type": "container",
      "height": 44,
      "layout": {
        "dir": "column",
        "align": "center",
        "justify": "center",
        "gap": 4,
        "px": 24,
        "py": 8
      },
      "radius": 6,
      "navigateTo": "add-expense",
      "overrides": {
        "cursor": "pointer",
        "flex": 1
      }
    },
    "add-expense-tab-icon": {
      "parent": "add-expense-tab",
      "order": 0,
      "catalog": "icon",
      "overrides": {
        "name": "plus"
      },
      "color": "text-secondary"
    },
    "add-expense-tab-label": {
      "parent": "add-expense-tab",
      "order": 1,
      "type": "text",
      "content": "Add Expense",
      "typography": "label",
      "color": "text-secondary",
      "navigateTo": "add-expense"
    },
    "insights-tab": {
      "parent": "nav-tabs",
      "order": 2,
      "type": "container",
      "height": 44,
      "layout": {
        "dir": "column",
        "align": "center",
        "justify": "center",
        "gap": 4,
        "px": 24,
        "py": 8
      },
      "radius": 6,
      "navigateTo": "spending-insights",
      "overrides": {
        "cursor": "pointer",
        "flex": 1
      }
    },
    "insights-tab-icon": {
      "parent": "insights-tab",
      "order": 0,
      "catalog": "icon",
      "overrides": {
        "name": "bar-chart"
      },
      "color": "text-secondary"
    },
    "insights-tab-label": {
      "parent": "insights-tab",
      "order": 1,
      "type": "text",
      "content": "Insights",
      "typography": "label",
      "color": "text-secondary",
      "navigateTo": "spending-insights"
    }
  },
  "regions": {
    "header": [
      "top-bar",
      "nav-tabs"
    ]
  }
}