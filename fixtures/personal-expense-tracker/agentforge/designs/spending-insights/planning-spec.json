  "responsiveRules": [
    {
      "breakpoint": "desktop",
      "width": 1440,
      "behavior": "Full-width analytical layout with 1280px content max-width, 24px margins, 24px gutters on 12-column grid. PeriodSummaryHeader displays three StatCells in a horizontal row. DailySpendingChart, TopCategoriesCard, BiggestExpensesCard, and MonthComparisonCard stack vertically as full-width cards. ChartTypeToggle anchored top-right of DailySpendingCard header. ExportCSVButton right-aligned below all cards.",
      "layout": "single-column-centered",
      "changes": [
        "Content max-width 1280px centered with 24px side margins",
        "PeriodSummaryHeader: three StatCells in horizontal row with 24px column gap",
        "DailySpendingCard: full-width with ChartTypeToggle inline in card header top-right",
        "TopCategoriesCard: full-width with StackedCategoryBar above CategoryDetailRowList",
        "BiggestExpensesCard: full-width ranked list",
        "MonthComparisonCard: full-width with ComparisonBars and SpendingDiffBadge",
        "ExportCSVButton: right-aligned flush to content right boundary",
        "NavigationTabs: fixed bottom bar with three tabs",
        "NoDataEmptyState: centered in full content area below MonthSelector when visible"
      ]
    }
  ],
