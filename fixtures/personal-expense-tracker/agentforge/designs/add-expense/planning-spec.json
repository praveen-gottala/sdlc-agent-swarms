  "responsiveRules": [
    {
      "breakpoint": "desktop",
      "width": 1440,
      "behavior": "Single-column centered layout with max-width 1280px and 24px horizontal margins. All form sections displayed as full-width cards stacked vertically with 24px gap. QuickAddSuggestions renders as a horizontal scroll row above the hero input. CategoryChipGrid and PaymentMethodChipRow display chips in a wrapping flex row. MiniCalendarDropdown anchors below DatePickerInput trigger. NavigationTabs fixed at bottom.",
      "layout": "single-column",
      "changes": [
        "Content centered with content-max-width constraint and 24px grid-margin",
        "TopBar spans full width at 64px height with back arrow, contextual title, and settings icon",
        "QuickAddSuggestions renders as horizontally scrollable chip row with 12px gap",
        "AmountHeroSection card at full content width with 32px paddingY and 48px hero font size",
        "CategoryChipGrid chips wrap in flex-wrap row with 8px gap, pill border-radius",
        "NewCategoryInlineForm expands inline below chip grid with 16px padding on navy-raised surface",
        "ColorPickerRow renders as horizontal swatch row within NewCategoryInlineForm",
        "DatePickerInput full-width trigger; MiniCalendarDropdown floats below with elevation-2 shadow",
        "PaymentMethodChipRow chips wrap in flex-wrap row with 8px gap, pill border-radius",
        "NoteInput full-width textarea with CharacterCounter right-aligned below",
        "SaveExpenseButton full-width at bottom of form stack with 44px min-height",
        "NavigationTabs fixed bottom bar at 64px height with three tabs"
      ]
    }
  ],
