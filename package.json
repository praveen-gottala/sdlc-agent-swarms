    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@swc/core": "^1.15.18",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/react": "^19.1.6",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "eventemitter3": "^5.0.4",
    "jest": "^29.7.0",
