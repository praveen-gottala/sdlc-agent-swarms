    {
      "breakpoint": "desktop",
      "width": 1440,
      "behavior": "Two-column layout: left column (5/12) holds BudgetSummaryCard and CategoryDonutChartCard; right column (7/12) holds CategoryFilterDropdown and RecentExpensesList. TopBar spans full width at 64px height. NavigationTabs sticky at bottom with 64px height. Content max-width 1280px centered with 24px margins.",
      "layout": "two-column",
      "changes": [
        "Full TopBar with MonthSelector centered and SettingsIconButton right-aligned",
        "Left column (5 of 12 grid columns): BudgetSummaryCard stacked above CategoryDonutChartCard with 24px gap",
        "Right column (7 of 12 grid columns): CategoryFilterDropdown chip bar above scrollable RecentExpensesList",
        "CategoryDonutChart rendered at 200px diameter with CategoryLegend alongside",
        "ExpenseDetailPopover anchored inline to ExpenseRow at dropdown z-index",
        "NavigationTabs sticky bottom bar with Home, Add Expense, Insights tabs",
        "EmptyState centered in right column when no expenses exist"
      ]
    }
