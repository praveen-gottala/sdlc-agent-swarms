{
  "name": "test-app",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "jest",
    "test:e2e": "playwright test",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "figma:start": "docker compose up -d figma-bridge",
    "figma:stop": "docker compose down",
    "figma:logs": "docker compose logs -f figma-bridge",
    "figma:status": "docker compose ps figma-bridge",
    "figma:build-plugin": "bash docker/talk-to-figma/build-figma-plugin.sh"
  },
  "dependencies": {
    "@nx/js": "^22.6.0",
    "@prisma/client": "^5.22.0",
    "express": "^4.21.0",
    "next": "^14.2.0",
    "nx": "^22.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@swc/core": "^1.15.18",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "eventemitter3": "^5.0.4",
    "jest": "^29.7.0",
    "postcss": "^8.4.0",
    "prettier": "^3.4.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "yaml": "^2.8.2"
  }
}
