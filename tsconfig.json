{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"],
  "references": [
    {
      "path": "./packages/integration-tests"
    },
    {
      "path": "./packages/agents-design"
    },
    {
      "path": "./packages/agents-cicd"
    },
    {
      "path": "./packages/agents-code"
    },
    {
      "path": "./packages/agents-spec"
    },
    {
      "path": "./packages/governance"
    },
    {
      "path": "./packages/providers"
    },
    {
      "path": "./packages/channels"
    },
    {
      "path": "./packages/e2e-test"
    },
    {
      "path": "./packages/core"
    },
    {
      "path": "./packages/cli"
    },
    {
      "path": "./packages/agents-ux"
    }
  ]
}
