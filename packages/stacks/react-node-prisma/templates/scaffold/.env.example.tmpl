# {{PROJECT_NAME}} — environment variables
# Copy this file to .env and fill in the values.

# Application
DATABASE_URL=postgresql://user:password@localhost:5432/{{PROJECT_NAME}}
NEXT_PUBLIC_APP_URL=http://localhost:3000

# LLM Provider (required)
# Choose one provider and configure its auth method

# Option 1: Anthropic Claude (API key)
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Option 2: OpenAI (API key)
# OPENAI_API_KEY=

# Option 3: Google Vertex AI (Application Default Credentials)
# Run `gcloud auth application-default login` to authenticate
# Or set GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
#
# AgentForge-specific variables:
# AGENTFORGE_VERTEX_PROJECT_ID=my-gcp-project
# AGENTFORGE_VERTEX_REGION=us-central1
# AGENTFORGE_USE_VERTEX=true
#
# Or use Claude Code compatible variables (if already configured):
# ANTHROPIC_VERTEX_PROJECT_ID=my-gcp-project
# CLOUD_ML_REGION=us-central1
# CLAUDE_CODE_USE_VERTEX=1
#
# Both formats are auto-detected. If you already have Claude Code configured,
# no changes needed!

# Option 4: Azure OpenAI (bearer token)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Slack Integration (if enabled during init)
# Create a Slack app at https://api.slack.com/apps
# Required scopes: chat:write, channels:read, users:read
AGENTFORGE_SLACK_BOT_TOKEN=
AGENTFORGE_SLACK_APP_TOKEN=

# Telegram Integration (if enabled during init)
# Talk to @BotFather on Telegram to create a bot
AGENTFORGE_TELEGRAM_BOT_TOKEN=

# Figma MCP (optional)
# docker compose up -d figma-bridge
AGENTFORGE_MCP_FIGMA_WRITE_URL=ws://localhost:3055
# https://www.figma.com/developers/api#access-tokens
AGENTFORGE_MCP_FIGMA_TOKEN=
# figma.com/design/<FILE_ID>/...
AGENTFORGE_MCP_FIGMA_FILE_ID=
# Penpot MCP (optional)
# AGENTFORGE_MCP_PENPOT_URL=http://localhost:4401/mcp

# AgentForge Engine (auto-configured)
AGENTFORGE_ENGINE_PORT=8321
