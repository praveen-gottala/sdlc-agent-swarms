        "transform": "merchantName"
      },
      {
        "entityId": "entity-expense",
        "field": "amount",
        "source": "/api/expenses/{id}",
        "transform": "amount"
      },
      {
        "entityId": "entity-expense",
        "field": "date",
        "source": "/api/expenses/{id}",
        "transform": "date | formatDate"
