{
  "name": "@agentforge/agents-architect",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "!{projectRoot}/src/**/*.test.ts",
        "{projectRoot}/src/prompts/**/*.md",
        "{projectRoot}/tsconfig.lib.json",
        "{projectRoot}/tsconfig.json"
      ],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "commands": [
          "tsc --build tsconfig.lib.json",
          "mkdir -p dist/prompts && cp -r src/prompts/* dist/prompts/"
        ],
        "cwd": "packages/agents-architect",
        "parallel": false
      },
      "dependsOn": ["build-deps"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/agents-architect",
        "command": "jest"
      },
      "configurations": {}
    }
  }
}
