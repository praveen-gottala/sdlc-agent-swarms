{
  "name": "test-app",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/designspec-renderer/src/renderer/browser/app",
    "fixtures/agentforge-brownfield-app"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "jest",
    "test:e2e": "playwright test",
    "db:migrate": "prisma migrate dev",
