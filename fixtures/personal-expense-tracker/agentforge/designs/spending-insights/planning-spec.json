  "responsiveRules": [
    {
      "breakpoint": "desktop",
      "width": 1440,
      "behavior": "Full-width multi-column layout with 24px gutters and 1280px max content width. PeriodSummaryHeader displays 3 StatCells in a horizontal row. DailySpendingChart spans full content width. TopCategoriesCard and BiggestExpensesCard displayed side-by-side in a 2-column row. MonthComparisonCard spans full width below. ExportCSVButton right-aligned below all cards.",
      "layout": "multi-column",
      "changes": [
        "PeriodSummaryHeader: 3-column equal-width StatCell grid with 24px column gap",
        "DailySpendingChart: full content width, 280px chart height",
        "TopCategoriesCard and BiggestExpensesCard: 2-column side-by-side layout with 24px gap, each ~50% width",
        "MonthComparisonCard: full content width",
        "ExportCSVButton: right-aligned flex row below MonthComparisonCard",
        "NavigationTabs: horizontal tab bar at bottom of viewport",
        "TopBar: fixed top bar with 64px height",
        "MonthSelector: inline within TopBar or directly below it",
        "NoDataEmptyState: occupies same spatial footprint as replaced content to prevent layout shift"
      ]
    }
  ],
