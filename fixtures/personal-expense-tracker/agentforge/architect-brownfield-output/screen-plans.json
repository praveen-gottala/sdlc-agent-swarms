      },
      {
        "entityId": "entity-recurring-template",
        "field": "status",
        "source": "/api/recurring-templates",
        "transform": "items.filter(status=ACTIVE).length — populates drawer-summary-row activeCount"
      },
      {
        "entityId": "entity-recurring-template",
        "field": "amount",
        "source": "/api/recurring-templates",
        "transform": "items.filter(status=ACTIVE).reduce(sum by frequency normalized to monthly) — populates drawer-summary-row estimatedMonthlyTotal"
