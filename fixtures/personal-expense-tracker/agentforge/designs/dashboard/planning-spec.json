  "responsiveRules": [
    {
      "breakpoint": "desktop",
      "width": 1440,
      "behavior": "Two-column layout: fixed 360px left summary column + flexible right expense column, 24px gap, 32px outer padding, max-width 1280px centered",
      "layout": "two-column",
      "changes": [
        "TopBar sticky at 64px height with full logo and Add Expense button",
        "NavigationTabs full-width with three tabs and sliding amber underline indicator",
        "MonthSelector pill centered below TopBar",
        "Left column fixed at 360px: BudgetSummaryCard, CategoryDonutChart (160px), CategoryLegend stacked vertically with 24px gap",
        "Right column flexible: CategoryFilterDropdown chip at top, RecentExpensesList scrollable below with 8px row gap",
        "ExpenseDetailPopover anchored right of clicked ExpenseRow at 320px width",
        "EmptyState centered in right column when no expenses",
        "SettingsDialog as overlay modal at z-index 1200"
      ]
    }
  ],
