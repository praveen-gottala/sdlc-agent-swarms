      "end-date-row",
      "end-date-never-radio",
      "end-date-on-date-radio",
      "end-date-picker-input"
    ],
    "dataBindings": [
      {
        "entityId": "entity-recurring-template",
        "field": "frequency",
        "source": "/api/recurring-templates/{id}",
        "transform": "frequency | default:MONTHLY — pre-fills FrequencyChipSelector when isEditingSeries=true"
      },
      {
        "entityId": "entity-recurring-template",
        "field": "endDate",
        "source": "/api/recurring-templates/{id}",
        "transform": "endDate | toEndDateMode — maps presence to ON_DATE or NEVER"
      },
      {
        "entityId": "entity-recurring-template",
        "field": "startDate",
        "source": "/api/recurring-templates/{id}",
        "transform": "startDate — used as minDate anchor for end-date-picker-input"
      },
      {
        "entityId": "entity-recurring-template",
        "field": "merchantName",
        "source": "/api/recurring-templates/{id}",
        "transform": "merchantName — pre-fills form merchant field when editing series"
      },
      {
        "entityId": "entity-recurring-template",
        "field": "amount",
        "source": "/api/recurring-templates/{id}",
        "transform": "amount — pre-fills form amount field when editing series"
      },
      {
        "entityId": "entity-recurring-template",
        "field": "categoryId",
        "source": "/api/recurring-templates/{id}",
        "transform": "categoryId — pre-selects category when editing series"
      },
      {
        "entityId": "entity-recurring-template",
        "field": "paymentMethod",
        "source": "/api/recurring-templates/{id}",
        "transform": "paymentMethod — pre-selects payment method chip when editing series"
      },
      {
        "entityId": "entity-recurring-template",
        "field": "note",
        "source": "/api/recurring-templates/{id}",
        "transform": "note — pre-fills note input when editing series"
      }
    ],
    "navigationTargets": [
      {
        "target": "screen-001",
        "trigger": "form submit success (POST /api/recurring-templates + POST /api/expenses)"
      },
      {
        "target": "screen-001",
        "trigger": "form submit success (PUT /api/recurring-templates/{id} — edit series save)"
      },
      {
        "target": "screen-001",
        "trigger": "cancel / back action"
      }
    ]
  },
  {
