{
  "screen": "__chrome__",
  "width": 1440,
  "nodes": {
    "root": {
      "parent": null,
      "order": 0,
      "type": "page",
      "width": 1440,
      "layout": {
        "dir": "column",
        "gap": 0
      },
      "background": "background-primary"
    },
    "top-bar": {
      "parent": "root",
      "order": 0,
      "type": "container",
      "width": 1440,
      "height": 64,
      "background": "surface-primary",
      "shadow": "sm",
      "layout": {
        "dir": "row",
        "align": "center",
        "justify": "space-between",
        "px": 24,
        "gap": 16
      },
      "overrides": {
        "borderBottom": "1px solid var(--border-default)",
        "zIndex": 100
      }
    },
    "month-selector": {
      "parent": "top-bar",
      "order": 0,
      "type": "container",
      "layout": {
        "dir": "row",
        "align": "center",
        "gap": 8
      }
    },
    "month-prev-btn": {
      "parent": "month-selector",
      "order": 0,
      "catalog": "button-ghost",
      "label": "",
      "overrides": {
        "icon": "chevron-left",
        "aria-label": "Previous month",
        "padding": "4px 8px"
      }
    },
    "month-label": {
      "parent": "month-selector",
      "order": 1,
      "type": "text",
      "content": "January 2025",
      "typography": "heading-2",
      "color": "text-primary",
      "weight": 700
    },
    "month-next-btn": {
      "parent": "month-selector",
      "order": 2,
      "catalog": "button-ghost",
      "label": "",
      "overrides": {
        "icon": "chevron-right",
        "aria-label": "Next month",
        "padding": "4px 8px"
      }
    },
    "top-bar-actions": {
      "parent": "top-bar",
      "order": 1,
      "type": "container",
      "layout": {
        "dir": "row",
        "align": "center",
        "gap": 12
      }
    },
    "top-bar-settings-trigger": {
      "parent": "top-bar-actions",
      "order": 0,
      "catalog": "button-ghost",
      "label": "",
      "navigateTo": "settings",
      "overrides": {
        "icon": "settings",
        "aria-label": "Open settings"
      }
    },
    "top-bar-add-button": {
      "parent": "top-bar-actions",
      "order": 1,
      "catalog": "button-primary",
      "label": "Add Expense",
      "navigateTo": "add-expense",
      "overrides": {
        "icon": "plus",
        "aria-label": "Add new expense",
        "borderRadius": "10px"
      }
    },
    "nav-tabs": {
      "parent": "root",
      "order": 1,
      "type": "container",
      "width": 1440,
      "height": 64,
      "background": "surface-primary",
      "layout": {
        "dir": "row",
        "align": "center",
        "justify": "center",
        "px": 24,
        "gap": 0
      },
      "overrides": {
        "borderTop": "1px solid var(--border-default)",
        "zIndex": 110
      }
    },
    "nav-tab-home": {
      "parent": "nav-tabs",
      "order": 0,
      "type": "container",
      "layout": {
        "dir": "column",
        "align": "center",
        "gap": 4,
        "px": 32,
        "py": 8
      },
      "overrides": {
        "cursor": "pointer",
        "flex": "1",
        "maxWidth": "200px"
      }
    },
    "nav-tab-home-icon": {
      "parent": "nav-tab-home",
      "order": 0,
      "catalog": "icon",
      "overrides": {
        "name": "home",
        "color": "var(--cta-primary)"
      }
    },
    "nav-tab-home-label": {
      "parent": "nav-tab-home",
      "order": 1,
      "type": "text",
      "content": "Home",
      "typography": "label",
      "color": "cta-primary",
      "weight": 600
    },
    "nav-tab-add-expense": {
      "parent": "nav-tabs",
      "order": 1,
      "type": "container",
      "layout": {
        "dir": "column",
        "align": "center",
        "gap": 4,
        "px": 32,
        "py": 8
      },
      "navigateTo": "add-expense",
      "overrides": {
        "cursor": "pointer",
        "flex": "1",
        "maxWidth": "200px"
      }
    },
    "nav-tab-add-icon": {
      "parent": "nav-tab-add-expense",
      "order": 0,
      "catalog": "icon",
      "overrides": {
        "name": "plus",
        "color": "var(--text-secondary)"
      }
    },
    "nav-tab-add-label": {
      "parent": "nav-tab-add-expense",
      "order": 1,
      "type": "text",
      "content": "Add Expense",
      "typography": "label",
      "color": "text-secondary"
    },
    "nav-tab-insights": {
      "parent": "nav-tabs",
      "order": 2,
      "type": "container",
      "layout": {
        "dir": "column",
        "align": "center",
        "gap": 4,
        "px": 32,
        "py": 8
      },
      "navigateTo": "spending-insights",
      "overrides": {
        "cursor": "pointer",
        "flex": "1",
        "maxWidth": "200px"
      }
    },
    "nav-tab-insights-icon": {
      "parent": "nav-tab-insights",
      "order": 0,
      "catalog": "icon",
      "overrides": {
        "name": "bar-chart",
        "color": "var(--text-secondary)"
      }
    },
    "nav-tab-insights-label": {
      "parent": "nav-tab-insights",
      "order": 1,
      "type": "text",
      "content": "Insights",
      "typography": "label",
      "color": "text-secondary"
    }
  },
  "regions": {
    "header": [
      "top-bar"
    ],
    "footer": [
      "nav-tabs"
    ]
  }
}