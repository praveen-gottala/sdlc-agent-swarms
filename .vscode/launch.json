    ],
    "inputs": [
        {
            "id": "projectDir",
            "type": "promptString",
            "description": "Sub-project directory to run against (e.g. zen-mode)",
            "default": "zen-mode"
        },
        {
            "id": "appDir",
            "type": "promptString",
            "description": "Target directory for agentforge init (created under cwd)",
            "default": "my-debug-app"
        },
        {
            "id": "phase",
            "type": "pickString",
            "description": "SDLC phase to start",
            "options": [
                "design",
                "spec",
                "code",
                "cicd",
                "observe"
            ]
        },
        {
            "id": "taskId",
            "type": "promptString",
            "description": "Task ID"
        },
        {
            "id": "feedback",
            "type": "promptString",
            "description": "Feedback / change description"
        },
        {
            "id": "configKey",
            "type": "promptString",
            "description": "Config key (dot-notation, e.g. budget.per_task_max_usd)"
        },
        {
            "id": "configValue",
            "type": "promptString",
            "description": "Config value to set"
        },
        {
            "id": "description",
            "type": "promptString",
            "description": "Natural language description of what to design"
        },
        {
            "id": "pageId",
            "type": "promptString",
            "description": "Page ID from pages.yaml (e.g. bill-entry)",
            "default": "bill-entry"
        },
        {
            "id": "penpotUrl",
            "type": "promptString",
            "description": "Penpot workspace URL"
        },
        {
            "id": "mockFlag",
            "type": "pickString",
            "description": "Use mock LLM responses instead of real API calls?",
            "options": [
                { "label": "No", "value": "" },
                { "label": "Yes (--mock)", "value": "--mock" }
            ]
        },
        {
            "id": "freshFlag",
            "type": "pickString",
            "description": "Regenerate from scratch, ignoring cached results?",
            "options": [
                { "label": "No", "value": "" },
                { "label": "Yes (--fresh)", "value": "--fresh" }
            ]
        },
        {
            "id": "evaluateFlag",
            "type": "pickString",
            "description": "Run design evaluation after rendering?",
            "options": [
                { "label": "No", "value": "" },
                { "label": "Yes (--evaluate)", "value": "--evaluate" }
            ]
        },
        {
            "id": "headlessFlag",
            "type": "pickString",
            "description": "Run browser in headless mode?",
            "options": [
                { "label": "No", "value": "" },
                { "label": "Yes (--headless)", "value": "--headless" }
            ]
        },
        {
            "id": "watchFlag",
            "type": "pickString",
            "description": "Watch for status changes continuously?",
            "options": [
                { "label": "No", "value": "" },
                { "label": "Yes (--watch)", "value": "--watch" }
            ]
        },
        {
            "id": "dryFlag",
            "type": "pickString",
            "description": "Dry run — show what would change without applying?",
            "options": [
                { "label": "No", "value": "" },
                { "label": "Yes (--dry)", "value": "--dry" }
            ]
        },
        {
            "id": "allFlag",
            "type": "pickString",
            "description": "Apply to all tasks?",
            "options": [
                { "label": "No", "value": "" },
                { "label": "Yes (--all)", "value": "--all" }
            ]
        },
        {
            "id": "evalScenario",
            "type": "pickString",
            "description": "Eval scenario to run",
            "options": [
                "pomodoro",
                "habit-tracker",
                "force-multi-round",
                "escalation"
            ]
        },
        {
            "id": "changesFlag",
            "type": "pickString",
            "description": "Include change feedback?",
            "options": [
                { "label": "No", "value": "" },
                { "label": "Yes (--changes)", "value": "--changes" }
            ]
        }
    ]
}
