  "responsiveRules": [
    {
      "breakpoint": "desktop",
      "width": 1440,
      "behavior": "Full analytical layout at 1280px max-width centered with 24px margins. PeriodSummaryHeader displays three StatCells in a horizontal row. DailySpendingChartCard spans full content width. TopCategoriesCard and BiggestExpensesCard sit side-by-side in a two-column grid. MonthComparisonCard spans full width below. ExportCSVButton right-aligned below all cards.",
      "layout": "multi-column",
      "changes": [
        "PeriodSummaryHeader: 3-column horizontal StatCell row with 24px column gap",
        "DailySpendingChartCard: full 12-column width, 320px height",
        "TopCategoriesCard and BiggestExpensesCard: 6-column each, side-by-side with 24px gutter",
        "MonthComparisonCard: full 12-column width",
        "ExportCSVButton: right-aligned, 44px height, below MonthComparisonCard",
        "NavigationTabs: horizontal tab bar at bottom, 64px height",
        "TopBar: full-width, 64px height with logo and Add Expense button",
        "Content max-width 1280px centered within 1440px viewport"
      ]
    }
  ],
