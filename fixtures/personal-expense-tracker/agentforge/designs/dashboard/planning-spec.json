  "responsiveRules": [
    {
      "breakpoint": "desktop",
      "width": 1440,
      "behavior": "Two-column layout with 24px gutter, max-width 1280px centered with 24px margin. Left column (5/12) holds BudgetSummaryCard and CategoryDonutChart stacked vertically. Right column (7/12) holds filter bar and scrollable RecentExpensesList. TopBar and NavigationTabs span full width.",
      "layout": "two-column",
      "changes": [
        "Full-width TopBar with MonthSelector centered and settings icon right-aligned",
        "Left column (5 of 12 grid columns) for budget summary and donut chart",
        "Right column (7 of 12 grid columns) for expense list with filter dropdown",
        "RecentExpensesList fixed height 520px with internal scroll",
        "NavigationTabs sticky at bottom with 64px height and z-index sticky",
        "CategoryDonutChart rendered at 220px diameter with adjacent CategoryLegend",
        "ExpenseDetailPopover rendered as floating overlay at elevation-2",
        "SettingsDialog rendered as centered modal at elevation-3 with overlay backdrop"
      ]
    }
